class PlaywrightSolver:
    def __init__(self, config: SolverConfig):
        self.config = config
        self._vision = VisionEngine(config)
        self._detector = ChallengeDetector(config)
        self._playwright = None
        self._browser = None
        self._context = None

    async def __aenter__(self) -> 'PlaywrightSolver':
        await self.initialize()
        return self

    async def __aexit__(self, *args) -> None:
        await self.close()

    async def initialize(self) -> None:
        if not PLAYWRIGHT_AVAILABLE:
            raise BrowserNotAvailableError("Playwright not installed")

        self._playwright = await async_playwright().start()
        browser_type = getattr(self._playwright, self.config.browser_type)
        args = StealthPatcher.get_stealth_args(self.config)

        if self.config.user_data_dir:
            self._context = await browser_type.launch_persistent_context(
                user_data_dir=self.config.user_data_dir, **args
            )
        else:
            self._browser = await browser_type.launch(**args)
            self._context = await self._browser.new_context(
                viewport={'width': self.config.viewport_width, 'height': self.config.viewport_height},
                user_agent=random.choice(StealthPatcher.USER_AGENTS)
            )

        await self._context.add_init_script(StealthPatcher.STEALTH_SCRIPT)
        logger.info("Playwright initialized with stealth")

    async def solve(self, url: str) -> bool:
        page = await self._context.new_page()
        try:
            await page.goto(url, wait_until='networkidle', timeout=30000)
            await asyncio.sleep(2)

            if await self._click_checkbox(page):
                logger.info("Checkbox clicked, waiting for challenge")
                await asyncio.sleep(2)

            for attempt in range(self.config.max_retries):
                state = await self._detector.detect_playwright(page)
                if state is None or not state.target_label:
                    logger.info("No active challenge detected")
                    return True

                logger.info(f"Attempt {attempt + 1}: {state.challenge_type.name} - {state.target_label}")

                if await self._solve_image_challenge(page, state):
                    logger.info("Challenge solved successfully")
                    return True

                await asyncio.sleep(1)

            return False
        finally:
            await page.close()

    async def _click_checkbox(self, page: Any) -> bool:
        try:
            frame_loc = page.locator(self._detector.HCAPTCHA_SELECTORS['frame']).first
            if await frame_loc.count() == 0:
                return False

            frame = await frame_loc.content_frame()
            if not frame:
                return False

            checkbox = frame.locator(self._detector.HCAPTCHA_SELECTORS['checkbox'])
            if await checkbox.count() > 0:
                await self._human_click(frame, checkbox)
                return True
        except Exception as e:
            logger.error(f"Checkbox click error: {e}")
        return False

    async def _solve_image_challenge(self, page: Any, state: ChallengeState) -> bool:
        try:
            frame_loc = page.locator(self._detector.HCAPTCHA_SELECTORS['frame']).first
            frame = await frame_loc.content_frame()

            cells = frame.locator('.task-image')
            cell_count = await cells.count()

            to_click = []
            for i in range(min(cell_count, 9)):
                cell = cells.nth(i)
                box = await cell.bounding_box()
                if not box:
                    continue

                screenshot = await frame.screenshot(
                    clip={'x': box['x'], 'y': box['y'],
                          'width': box['width'], 'height': box['height']}
                )

                img_array = np.frombuffer(screenshot, np.uint8)
                image = cv2.imdecode(img_array, cv2.IMREAD_COLOR)
                image = self._vision.preprocess_image(image)

                target = state.target_label
                detections = self._vision.detect_objects(image, [target] if target else None)
                semantic = self._vision.semantic_match(image, target or "")

                if detections or semantic > 0.5:
                    to_click.append(cell)
                    logger.debug(f"Cell {i}: detections={len(detections)}, semantic={semantic:.2f}")

            for cell in to_click:
                await self._human_click(frame, cell)
                await asyncio.sleep(random.uniform(0.3, 0.8))

            submit = frame.locator(self._detector.HCAPTCHA_SELECTORS['submit_button'])
            if await submit.count() > 0:
                await self._human_click(frame, submit)

            await asyncio.sleep(3)
            return await self._detector.detect_playwright(page) is None

        except Exception as e:
            logger.error(f"Solve error: {e}")
            return False

    async def _human_click(self, frame: Any, locator: Any) -> None:
        try:
            box = await locator.bounding_box()
            if not box:
                await locator.click(timeout=5000)
                return

            x = box['x'] + random.uniform(box['width'] * 0.25, box['width'] * 0.75)
            y = box['y'] + random.uniform(box['height'] * 0.25, box['height'] * 0.75)

            steps = random.randint(8, 20) if self.config.human_like_mouse else 1
            await frame.mouse.move(x, y, steps=steps)
            await asyncio.sleep(random.uniform(0.05, 0.2))
            await frame.mouse.click(x, y, button='left')
        except Exception:
            await locator.click(force=True)

    async def close(self) -> None:
        if self._context:
            await self._context.close()
        if self._browser:
            await self._browser.close()
        if self._playwright:
            await self._playwright.stop()

# =============================================================================
# SELENIUM SOLVER
# =============================================================================

class SeleniumSolverWrapper:
    def __init__(self, config: SolverConfig):
        self.config = config
        self._vision = VisionEngine(config)
        self._detector = ChallengeDetector(config)
        self._driver = None

    def solve(self, url: str) -> bool:
        if not self._driver:
            self._init_driver()

        self._driver.get(url)
        time.sleep(2)

        for attempt in range(self.config.max_retries):
            state = self._detector.detect_selenium(self._driver)
            if not state or not state.target_label:
                return True

            logger.info(f"Attempt {attempt + 1}: {state.challenge_type.name}")

            if self._solve_hcaptcha(state):
                return True
            time.sleep(1)

        return False

    def _init_driver(self) -> None:
        if not SELENIUM_AVAILABLE:
            raise BrowserNotAvailableError("Selenium not installed")

        options = StealthPatcher.get_selenium_options(self.config)
        self._driver = webdriver.Chrome(options=options)
        self._driver.execute_cdp_cmd('Page.addScriptToEvaluateOnNewDocument', {
            'source': StealthPatcher.STEALTH_SCRIPT
        })
        logger.info("Selenium initialized")

    def _solve_hcaptcha(self, state: ChallengeState) -> bool:
        try:
            frames = self._driver.find_elements(By.CSS_SELECTOR, self._detector.HCAPTCHA_SELECTORS['frame'])
            if not frames:
                return False

            self._driver.switch_to.frame(frames[0])

            images = self._driver.find_elements(By.CSS_SELECTOR, 'img')
            images = [img for img in images if img.is_displayed()][:9]

            for img in images:
                src = img.get_attribute('src') or ''
                if src.startswith('data:image'):
                    _, encoded = src.split(',', 1)
                    img_data = base64.b64decode(encoded)
                else:
                    img_data = img.screenshot_as_png

                arr = np.frombuffer(img_data, np.uint8)
                image = cv2.imdecode(arr, cv2.IMREAD_COLOR)

                if image is not None:
                    image = self._vision.preprocess_image(image)
                    if self._vision.detect_objects(image, [state.target_label]):
                        from selenium.webdriver.common.action_chains import ActionChains
                        ActionChains(self._driver).move_to_element(img).pause(random.uniform(0.2, 0.4)).click().perform()
                        time.sleep(random.uniform(0.3, 0.6))

            submit = self._driver.find_elements(By.CSS_SELECTOR, self._detector.HCAPTCHA_SELECTORS['submit_button'])
            if submit:
                submit[0].click()

            time.sleep(3)
            self._driver.switch_to.default_content()
            return self._detector.detect_selenium(self._driver) is None

        except Exception as e:
            logger.error(f"Selenium solve error: {e}")
            self._driver.switch_to.default_content()
            return False

    def close(self) -> None:
        if self._driver:
            self._driver.quit()

# =============================================================================
# UNIFIED SOLVER
# =============================================================================

class GodSolver:
    def __init__(self, config: Optional[SolverConfig] = None):
        self.config = config or SolverConfig()
        self._active_solver = None
        self._backend: Optional[BackendType] = None

    async def __aenter__(self) -> 'GodSolver':
        return self

    async def __aexit__(self, *args) -> None:
        await self.close()

    async def solve(self, url: str, backend: str = "auto") -> bool:
        if backend == "auto":
            backend = "playwright" if PLAYWRIGHT_AVAILABLE else "selenium"

        self._backend = BackendType(backend)

        if self._backend == BackendType.PLAYWRIGHT:
            if not self._active_solver:
                self._active_solver = PlaywrightSolver(self.config)
                await self._active_solver.initialize()
            return await self._active_solver.solve(url)

        if self._backend == BackendType.SELENIUM:
            if not self._active_solver:
                self._active_solver = SeleniumSolverWrapper(self.config)
            return self._active_solver.solve(url)

        raise ValueError(f"Unknown backend: {backend}")

    async def close(self) -> None:
        if self._active_solver:
            await self._active_solver.close()

# =============================================================================
# ENTRY POINT
# =============================================================================

async def main() -> None:
    import argparse

    parser = argparse.ArgumentParser(
        description='The Godly CAPTCHA Solver - Advanced ML-powered solver',
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    parser.add_argument('url', nargs='?', help='Target URL with CAPTCHA')
    parser.add_argument('--backend', choices=['auto', 'playwright', 'selenium'], default='auto')
    parser.add_argument('--headless', action='store_true', help='Run in headless mode')
    parser.add_argument('--model-dir', type=str, help='Custom model directory')
    parser.add_argument('--debug', action='store_true', help='Enable debug logging')

    args = parser.parse_args()

    if args.debug:
        logging.getLogger('captchahub').setLevel(logging.DEBUG)

    config = SolverConfig(headless=args.headless)
    if args.model_dir:
        config.model_dir = Path(args.model_dir)

    async with GodSolver(config) as solver:
        if args.url:
            success = await solver.solve(args.url, backend=args.backend)
            logger.info(f"RESULT: {'SOLVED' if success else 'FAILED'}")
        else:
            parser.print_help()

if __name__ == '__main__':
    asyncio.run(main())
