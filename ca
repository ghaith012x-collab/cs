class VisionEngine:
    """Multi-backend vision engine with caching and fallback chains."""

    # Specialized CAPTCHA labels (not COCO classes)
    CAPTCHA_LABELS: Final[List[str]] = [
        'bus', 'car', 'truck', 'train', 'boat', 'airplane', 'bicycle',
        'motorcycle', 'traffic light', 'fire hydrant', 'stop sign',
        'cat', 'dog', 'bird', 'horse', 'sheep', 'cow', 'elephant', 'bear',
        'zebra', 'giraffe', 'potted plant', 'bench', 'chair', 'table',
        'sports ball', 'frisbee', 'kite', 'skateboard', 'surfboard',
        'tennis racket', 'bottle', 'cup', 'fork', 'knife', 'spoon', 'bowl',
        'apple', 'banana', 'orange', 'pizza', 'cake', 'donut', 'sandwich',
        'book', 'clock', 'vase', 'scissors', 'teddy bear', 'hair drier', 'toothbrush'
    ]

    # Color mappings for heuristic matching
    COLOR_MAP: Final[Dict[str, Tuple[List[int], List[int]]]] = {
        'bus': ([10, 50, 50], [30, 255, 200]),
        'car': ([90, 50, 50], [130, 255, 200]),
        'traffic light': ([0, 100, 100], [10, 255, 255]),
        'fire hydrant': ([0, 50, 150], [30, 255, 255]),
        'stop sign': ([0, 100, 100], [10, 255, 255]),
    }

    def __init__(self, config: SolverConfig):
        self.config = config
        self._device = torch.device('cuda' if torch and torch.cuda.is_available() else 'cpu') if torch else None
        self._yolo_model: Optional[Any] = None
        self._clip_model = None
        self._clip_processor = None
        self._onnx_session = None
        self._model_lock = threading.RLock()
        self._model_dir = config.model_dir or Path.home() / ".captcha_solver" / "models"
        self._init_models()

    def _init_models(self) -> None:
        """Initialize ML models with fallback chain."""
        if not np or not cv2:
            logger.warning("numpy or opencv not available, vision engine limited")
            return

        self._model_dir.mkdir(parents=True, exist_ok=True)

        if ULTRALYTICS_AVAILABLE and self._yolo_model is None:
            self._load_yolo()

        if ONNX_AVAILABLE and self._onnx_session is None and self._yolo_model is None:
            self._load_onnx()

    def _load_yolo(self) -> bool:
        """Load YOLO model with safe download."""
        try:
            model_path = ModelDownloader.get_yolo_model_path(self._model_dir)
            
            if not model_path.exists():
                logger.info(f"Downloading YOLOv8n to {model_path}")
                success = ModelDownloader.download(
                    ModelDownloader.MODEL_SOURCES['yolov8n'],
                    model_path
                )
                if not success:
                    logger.warning("YOLO download failed, falling back to ONNX or heuristic")
                    return False

            with self._model_lock:
                if self._yolo_model is None:
                    if ultralytics is None:
                        logger.warning("ultralytics not available")
                        return False
                    from ultralytics import YOLO
                    self._yolo_model = YOLO(str(model_path))
                    logger.info(f"YOLOv8n loaded on {self._device}")
            return True
        except Exception as e:
            logger.warning(f"YOLO init failed: {e}")
            return False

    def _load_onnx(self) -> bool:
        """Load ONNX model."""
        try:
            model_path = self._model_dir / "yolov8n.onnx"
            if model_path.exists():
                with self._model_lock:
                    if self._onnx_session is None:
                        if onnxruntime is None:
                            logger.warning("onnxruntime not available")
                            return False
                        self._onnx_session = onnxruntime.InferenceSession(str(model_path))
                logger.info("ONNX Runtime loaded")
                return True
        except Exception as e:
            logger.warning(f"ONNX init failed: {e}")
        return False

    def detect_objects(self, image: Any, target_classes: Optional[List[str]] = None) -> List[BoundingBox]:
        """Detect objects with automatic backend selection."""
        if not np or not cv2:
            return []

        with self._model_lock:
            if self._yolo_model is not None:
                return self._detect_yolo(image, target_classes)
            if self._onnx_session is not None:
                return self._detect_onnx(image, target_classes)
        return self._detect_heuristic(image, target_classes)

    def _detect_yolo(self, image: Any, target_classes: Optional[List[str]]) -> List[BoundingBox]:
        """Ultralytics YOLOv8 detection."""
        results = self._yolo_model(image, verbose=False, conf=self.config.confidence_threshold)
        detections = []

        for result in results:
            if result.boxes is None:
                continue
            for box in result.boxes:
                cls_id = int(box.cls[0])
                label = self.CAPTCHA_LABELS[cls_id] if cls_id < len(self.CAPTCHA_LABELS) else f"class_{cls_id}"
                conf = float(box.conf[0])

                if target_classes and label not in target_classes:
                    continue

                coords = box.xyxy[0].cpu().numpy()
                detections.append(BoundingBox(
                    x1=float(coords[0]), y1=float(coords[1]),
                    x2=float(coords[2]), y2=float(coords[3]),
                    confidence=conf, label=label
                ))
        return detections

    def _detect_onnx(self, image: Any, target_classes: Optional[List[str]]) -> List[BoundingBox]:
        """ONNX Runtime inference with proper post-processing."""
        input_img = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)
        original_h, original_w = input_img.shape[:2]
        input_img = cv2.resize(input_img, (640, 640)).astype(np.float32) / 255.0
        input_img = np.transpose(input_img, (2, 0, 1))[np.newaxis, ...]

        outputs = self._onnx_session.run(None, {'images': input_img})
        return self._postprocess_onnx(outputs, original_h, original_w, target_classes)

    def _postprocess_onnx(
        self, 
        outputs: Any, 
        original_h: int, 
        original_w: int,
        target_classes: Optional[List[str]]
    ) -> List[BoundingBox]:
        """Post-process ONNX outputs: decode, NMS, filter."""
        detections = []
        
        try:
            if len(outputs) == 0:
                return detections

            if isinstance(outputs, (list, tuple)):
                output = outputs[0]
            else:
                output = outputs

            if output.ndim == 3:
                output = output[0]

            if output.ndim != 2 or output.shape[1] < 6:
                return detections

            predictions = []
            for pred in output:
                x, y, w, h, conf = pred[:5]
                class_probs = pred[5:]
                
                if conf < self.config.confidence_threshold:
                    continue
                
                class_id = int(np.argmax(class_probs))
                class_conf = float(class_probs[class_id])
                total_conf = conf * class_conf
                
                if target_classes:
                    label = self.CAPTCHA_LABELS[class_id] if class_id < len(self.CAPTCHA_LABELS) else f"class_{class_id}"
                    if label not in target_classes:
                        continue
                else:
                    label = self.CAPTCHA_LABELS[class_id] if class_id < len(self.CAPTCHA_LABELS) else f"class_{class_id}"

                x1 = float((x - w / 2) * original_w / 640)
                y1 = float((y - h / 2) * original_h / 640)
                x2 = float((x + w / 2) * original_w / 640)
                y2 = float((y + h / 2) * original_h / 640)

                predictions.append((x1, y1, x2, y2, total_conf, label))

            detections = self._nms(predictions, self.config.iou_threshold)

        except Exception as e:
            logger.error(f"ONNX post-processing error: {e}")

        return detections

    def _nms(self, predictions: List[Tuple], iou_threshold: float) -> List[BoundingBox]:
        """Non-Maximum Suppression for bounding boxes."""
        if not predictions:
            return []

        predictions = sorted(predictions, key=lambda x: x[4], reverse=True)
        kept = []
        suppressed = set()

        for i, (x1, y1, x2, y2, conf, label) in enumerate(predictions):
            if i in suppressed:
                continue
            kept.append(BoundingBox(x1, y1, x2, y2, conf, label))

            for j, (x1j, y1j, x2j, y2j, confj, labelj) in enumerate(predictions[i+1:], i+1):
                if label != labelj:
                    continue
                iou = self._calculate_iou((x1, y1, x2, y2), (x1j, y1j, x2j, y2j))
                if iou > iou_threshold:
                    suppressed.add(j)

        return kept

    def _calculate_iou(self, box1: Tuple, box2: Tuple) -> float:
        """Calculate Intersection over Union."""
        x1 = max(box1[0], box2[0])
        y1 = max(box1[1], box2[1])
        x2 = min(box1[2], box2[2])
        y2 = min(box1[3], box2[3])

        intersection = max(0, x2 - x1) * max(0, y2 - y1)
        area1 = (box1[2] - box1[0]) * (box1[3] - box1[1])
        area2 = (box2[2] - box2[0]) * (box2[3] - box2[1])
        union = area1 + area2 - intersection

        return intersection / union if union > 0 else 0

    def _detect_heuristic(self, image: Any, target_classes: Optional[List[str]]) -> List[BoundingBox]:
        """Pure OpenCV fallback using contour analysis."""
        detections = []
        gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
        blurred = cv2.GaussianBlur(gray, (5, 5), 0)
        edges = cv2.Canny(blurred, 50, 150)

        contours, _ = cv2.findContours(edges, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

        for cnt in contours:
            area = cv2.contourArea(cnt)
            if area < 500:
                continue

            x, y, width, height = cv2.boundingRect(cnt)
            aspect = width / height if height > 0 else 0
            label = self._classify_object(aspect, area, width, height)

            if target_classes and label not in target_classes:
                continue

            confidence = min(1.0, area / 10000)

            detections.append(BoundingBox(
                x1=float(x), y1=float(y), x2=float(x + width), y2=float(y + height),
                confidence=confidence, label=label
            ))

        return detections

    def _classify_object(self, aspect: float, area: float, width: int, height: int) -> str:
        """Heuristic object classification with better thresholds."""
        if 0.8 < aspect < 1.2 and area > 3000:
            return 'sports ball'
        if aspect > 2.5 and area > 4000:
            return 'bus' if width > height else 'bench'
        if 1.5 < aspect < 2.5 and area > 3500:
            return 'car'
        if 0.3 < aspect < 0.7 and area > 2500:
            return 'traffic light'
        if 0.5 < aspect < 1.0 and area > 2000:
            return 'potted plant'
        if aspect > 3.0:
            return 'train'
        if aspect < 0.3:
            return 'stop sign'
        return 'object'

    def semantic_match(self, image: Any, text_query: str) -> float:
        """Semantic similarity using CLIP or histogram fallback."""
        if not text_query or not text_query.strip():
            return 0.0

        if self._clip_model is None and TRANSFORMERS_AVAILABLE:
            self._load_clip()

        if self._clip_model is not None:
            return self._clip_match(image, text_query)
        return self._histogram_match(image, text_query)

    def _load_clip(self) -> None:
        """Load CLIP model with caching."""
        try:
            if transformers is None:
                return
            from transformers import CLIPModel, CLIPProcessor
            
            model_name = "openai/clip-vit-base-patch32"
            
            with self._model_lock:
                if self._clip_model is not None:
                    return
                    
                self._clip_model = CLIPModel.from_pretrained(model_name)
                self._clip_processor = CLIPProcessor.from_pretrained(model_name)
                logger.info("CLIP model loaded")
        except Exception as e:
            logger.warning(f"CLIP init failed: {e}")

    def _clip_match(self, image: Any, text_query: str) -> float:
        """CLIP-based semantic matching."""
        try:
            if PIL is None:
                return 0.0
            from PIL import Image
            
            inputs = self._clip_processor(
                text=[text_query],
                images=Image.fromarray(cv2.cvtColor(image, cv2.COLOR_BGR2RGB)),
                return_tensors="pt", padding=True
            )
            outputs = self._clip_model(**inputs)
            score = torch.sigmoid(outputs.logits_per_image[0][0]).item()
            return score
        except Exception as e:
            logger.debug(f"CLIP match error: {e}")
            return 0.0

    def _histogram_match(self, image: Any, text_query: str) -> float:
        """Color histogram heuristic matching with calibration."""
        hsv = cv2.cvtColor(image, cv2.COLOR_BGR2HSV)

        text_lower = text_query.lower()
        
        for keyword, (lower, upper) in self.COLOR_MAP.items():
            if keyword in text_lower:
                mask = cv2.inRange(hsv, np.array(lower), np.array(upper))
                ratio = cv2.countNonZero(mask) / (image.shape[0] * image.shape[1])
                return min(1.0, ratio * 3)
        return 0.3

    def preprocess_image(self, image: Any) -> Any:
        """Image enhancement for better detection."""
        if image is None:
            return image
        denoised = cv2.fastNlMeansDenoisingColored(image, None, 10, 10, 7, 21)
        lab = cv2.cvtColor(denoised, cv2.COLOR_BGR2LAB)
        l, a, b = cv2.split(lab)
        clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8, 8))
        enhanced = cv2.cvtColor(cv2.merge([clahe.apply(l), a, b]), cv2.COLOR_LAB2BGR)
        return enhanced

    def create_grid_cells(self, image: Any, rows: int = 3, cols: int = 3) -> List[BoundingBox]:
        """Divide image into grid cells."""
        if image is None:
            return []
        h, w = image.shape[:2]
        cell_h, cell_w = h // rows, w // cols

        cells = []
        for r in range(rows):
            for c in range(cols):
                x2 = (c + 1) * cell_w if c < cols - 1 else w
                y2 = (r + 1) * cell_h if r < rows - 1 else h
                cells.append(BoundingBox(
                    x1=float(c * cell_w), y1=float(r * cell_h),
                    x2=float(x2), y2=float(y2)
                ))
        return cells

