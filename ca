class ChallengeDetector:
    HCAPTCHA_SELECTORS: Final[Dict[str, str]] = {
        'frame': 'iframe[src*="hcaptcha.com"]',
        'checkbox': '#checkbox',
        'challenge_container': '.challenge-container',
        'prompt_text': '.prompt-text',
        'image_grid': '.task-image',
        'submit_button': '.button-submit',
        'next_button': '.button-next',
    }

    RECAPTCHA_SELECTORS: Final[Dict[str, str]] = {
        'frame': 'iframe[src*="recaptcha"]',
        'checkbox': '.recaptcha-checkbox',
        'challenge_frame': 'iframe[title*="challenge"]',
        'image_table': 'table.rc-imageselect-table',
        'tile': '.rc-imageselect-tile',
        'prompt': '.rc-imageselect-instructions',
        'verify_button': '#recaptcha-verify-button',
    }

    def __init__(self, config: SolverConfig):
        self.config = config

    async def detect_playwright(self, page: Any) -> Optional[ChallengeState]:
        state = ChallengeState()

        hcaptcha = page.locator(self.HCAPTCHA_SELECTORS['frame']).first
        if await hcaptcha.count() > 0:
            state.challenge_type = ChallengeType.HCAPTCHA_IMAGE_LABEL
            frame = await hcaptcha.content_frame()
            if frame:
                prompt = frame.locator(self.HCAPTCHA_SELECTORS['prompt_text'])
                if await prompt.count() > 0:
                    state.instruction_text = await prompt.inner_text()
                    state.target_label = self._extract_target(state.instruction_text)
            return state

        recaptcha = page.locator(self.RECAPTCHA_SELECTORS['frame']).first
        if await recaptcha.count() > 0:
            state.challenge_type = ChallengeType.RECAPTCHA_IMAGE
            frame = await recaptcha.content_frame()
            if frame:
                prompt = frame.locator(self.RECAPTCHA_SELECTORS['prompt'])
                if await prompt.count() > 0:
                    state.instruction_text = await prompt.inner_text()
                    state.target_label = self._extract_target(state.instruction_text)
            return state

        return None

    def detect_selenium(self, driver) -> Optional[ChallengeState]:
        state = ChallengeState()

        try:
            frames = driver.find_elements(By.CSS_SELECTOR, self.HCAPTCHA_SELECTORS['frame'])
            if frames:
                state.challenge_type = ChallengeType.HCAPTCHA_IMAGE_LABEL
                driver.switch_to.frame(frames[0])
                try:
                    prompt = driver.find_element(By.CSS_SELECTOR, self.HCAPTCHA_SELECTORS['prompt_text'])
                    state.instruction_text = prompt.text
                    state.target_label = self._extract_target(state.instruction_text)
                except Exception:
                    pass
                driver.switch_to.default_content()
                return state
        except Exception as e:
            logger.error(f"Selenium detection error: {e}")

        return None

    def _extract_target(self, prompt: str) -> str:
        prompt_lower = prompt.lower()

        patterns = [
            r'containing (?:an? )?([\w\s]+)',
            r'with ([\w\s]+)',
            r'(?:click|select) .*? ([\w\s]+)$',
        ]

        for pattern in patterns:
            match = re.search(pattern, prompt_lower)
            if match:
                target = match.group(1).strip().rstrip('.')
                return target.replace('motorbus', 'bus')

        for keyword in VisionEngine.HCAPTCHA_LABELS:
            if keyword in prompt_lower:
                return keyword

        return ""

