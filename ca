class ChallengeDetector:
    """DOM-based challenge detection and classification."""

    HCAPTCHA_SELECTORS: Final[Dict[str, List[str]]] = {
        'frame': ['iframe[src*="hcaptcha.com"]', 'iframe[src*="captcha.hcaptcha.com"]'],
        'checkbox': ['#checkbox', '.hcaptcha-checkbox'],
        'challenge_container': ['.challenge-container', '#challenge', '.hcaptcha-challenge'],
        'prompt_text': ['.prompt-text', '.challenge-title', '.instruction', 'h1'],
        'image_grid': ['.task-image', '.challenge-image', 'img[alt*="image"]'],
        'submit_button': ['.button-submit', '#submit-button', 'button[type="submit"]'],
        'next_button': ['.button-next', '#next-button', 'button.next'],
    }

    RECAPTCHA_SELECTORS: Final[Dict[str, List[str]]] = {
        'frame': ['iframe[src*="recaptcha"]', 'iframe[name="a-badge"]'],
        'checkbox': ['.recaptcha-checkbox', '#recaptcha-anchor'],
        'challenge_frame': ['iframe[title*="challenge"]', '.challenge-frame'],
        'image_table': ['table.rc-imageselect-table', '.select-checkbox'],
        'tile': ['.rc-imageselect-tile', 'div[role="checkbox"]'],
        'prompt': ['.rc-imageselect-instructions', '.challenge-text'],
        'verify_button': ['#recaptcha-verify-button', '.verify-button'],
    }

    def __init__(self, config: SolverConfig):
        self.config = config

    def _find_element(self, page_or_driver: Any, selectors: List[str]) -> Any:
        """Find element using multiple fallback selectors."""
        if hasattr(page_or_driver, 'locator'):
            for selector in selectors:
                try:
                    elem = page_or_driver.locator(selector).first
                    if elem:
                        count = elem.count() if hasattr(elem, 'count') else 0
                        if count > 0:
                            return elem
                except Exception:
                    continue
            return None
        else:
            for selector in selectors:
                try:
                    elem = page_or_driver.find_element(_By.CSS_SELECTOR, selector)
                    if elem is not None:
                        return elem
                except Exception:
                    continue
            return None

    async def detect_playwright(self, page: Any) -> Optional[ChallengeState]:
        """Detect challenge using Playwright with robust error handling."""
        state = ChallengeState()

        try:
            frame = self._find_element(page, self.HCAPTCHA_SELECTORS['frame'])
            if frame is not None:
                frame_count = await frame.count() if hasattr(frame, 'count') else 0
                if frame_count > 0:
                    state.challenge_type = ChallengeType.HCAPTCHA_IMAGE_LABEL
                    content_frame = await frame.content_frame()
                    if content_frame is not None:
                        prompt_elem = self._find_element(content_frame, self.HCAPTCHA_SELECTORS['prompt_text'])
                        if prompt_elem is not None:
                            try:
                                state.instruction_text = await prompt_elem.inner_text()
                                state.target_label = self._extract_target(state.instruction_text)
                            except Exception:
                                pass
                    return state

            frame = self._find_element(page, self.RECAPTCHA_SELECTORS['frame'])
            if frame is not None:
                frame_count = await frame.count() if hasattr(frame, 'count') else 0
                if frame_count > 0:
                    state.challenge_type = ChallengeType.RECAPTCHA_IMAGE
                    content_frame = await frame.content_frame()
                    if content_frame is not None:
                        prompt_elem = self._find_element(content_frame, self.RECAPTCHA_SELECTORS['prompt'])
                        if prompt_elem is not None:
                            try:
                                state.instruction_text = await prompt_elem.inner_text()
                                state.target_label = self._extract_target(state.instruction_text)
                            except Exception:
                                pass
                    return state

        except Exception as e:
            logger.debug(f"Challenge detection error: {e}")

        return None if state.challenge_type == ChallengeType.UNKNOWN else state

    def detect_selenium(self, driver: Any) -> Optional[ChallengeState]:
        """Detect challenge using Selenium with proper frame handling."""
        state = ChallengeState()

        try:
            frames = driver.find_elements(_By.CSS_SELECTOR, self.HCAPTCHA_SELECTORS['frame'][0])

            if frames:
                state.challenge_type = ChallengeType.HCAPTCHA_IMAGE_LABEL
                driver.switch_to.default_content()
                driver.switch_to.frame(frames[0])
                try:
                    prompt = self._find_element(driver, self.HCAPTCHA_SELECTORS['prompt_text'])
                    if prompt:
                        state.instruction_text = prompt.text
                        state.target_label = self._extract_target(state.instruction_text)
                except Exception:
                    pass
                finally:
                    driver.switch_to.default_content()
                return state

        except Exception as e:
            logger.error(f"Selenium detection error: {e}\n{traceback.format_exc()}")

        return None if state.challenge_type == ChallengeType.UNKNOWN else state

    def _extract_target(self, prompt: str) -> str:
        """Extract target object from challenge instruction."""
        if not prompt:
            return ""

        prompt_lower = prompt.lower()

        patterns = [
            r'containing (?:a|an? )?([\w\s]+?)(?:\s*[?.]|$)',
            r'with ([\w\s]+?)(?:\s*[?.]|$)',
            r'(?:click|select) on .*? ([\w\s]+?)(?:\s*[?.]|$)',
            r'identify (?:all )?(?:images with? )?([\w\s]+?)(?:\s*[?.]|$)',
            r'select (?:all )?([\w\s]+?)(?:\s*[?.]|$)',
        ]

        for pattern in patterns:
            match = re.search(pattern, prompt_lower)
            if match:
                target = match.group(1).strip().rstrip('.')
                target = target.replace('motorbus', 'bus')
                target = target.replace('vehicles', 'car')
                target = target.replace('a ', '').replace('an ', '')
                return target

        for keyword in VisionEngine.CAPTCHA_LABELS:
            if keyword in prompt_lower:
                return keyword

        return ""

