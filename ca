class PlaywrightSolver:
    """Async Playwright-based CAPTCHA solver with robust lifecycle management."""

    DEFAULT_TIMEOUT = 30000
    MAX_RETRIES = 3

    def __init__(self, config: SolverConfig):
        self.config = config
        self._vision = VisionEngine(config)
        self._detector = ChallengeDetector(config)
        self._playwright = None
        self._browser = None
        self._context = None
        self._initialized = False

    async def __aenter__(self) -> 'PlaywrightSolver':
        await self.initialize()
        return self

    async def __aexit__(self, exc_type, exc_val, exc_tb) -> None:
        await self.close()

    async def initialize(self) -> None:
        if not PLAYWRIGHT_AVAILABLE:
            raise BrowserNotAvailableError(
                "Playwright not installed. Run: pip install playwright && playwright install"
            )

        if self._initialized:
            return

        try:
            self._playwright = _async_playwright().start()
            browser_type = getattr(self._playwright, self.config.browser_type)
            args = StealthPatcher.get_stealth_args(self.config)

            if self.config.user_data_dir:
                self._context = await browser_type.launch_persistent_context(
                    user_data_dir=self.config.user_data_dir, **args
                )
            else:
                self._browser = await browser_type.launch(**args)
                self._context = await self._browser.new_context(
                    viewport={'width': self.config.viewport_width, 'height': self.config.viewport_height},
                    user_agent=random.choice(StealthPatcher.USER_AGENTS)
                )

            await self._context.add_init_script(StealthPatcher.STEALTH_SCRIPT)
            self._initialized = True
            logger.info("Playwright initialized with stealth")

        except Exception as e:
            logger.error(f"Playwright initialization failed: {e}")
            await self._safe_close()
            raise

    async def _safe_close(self) -> None:
        """Safe close that handles already-closed resources."""
        try:
            if self._context and not getattr(self._context, 'is_closed', lambda: False)():
                await self._context.close()
        except Exception:
            pass
        try:
            if self._browser:
                await self._browser.close()
        except Exception:
            pass
        try:
            if self._playwright:
                await self._playwright.stop()
        except Exception:
            pass

    async def solve(self, url: str) -> bool:
        """Solve CAPTCHA at given URL with timeout handling."""
        page = None
        try:
            page = await self._context.new_page()
            await page.goto(url, wait_until='networkidle', timeout=self.config.timeout * 1000)
            await asyncio.sleep(2)

            if await self._click_checkbox(page):
                logger.info("Checkbox clicked, waiting for challenge")
                await asyncio.sleep(2)

            for attempt in range(self.config.max_retries):
                state = await self._detector.detect_playwright(page)
                if state is None or not state.target_label:
                    logger.info("No active challenge detected")
                    return True

                logger.info(f"Attempt {attempt + 1}: {state.challenge_type.name} - {state.target_label}")

                if await self._solve_image_challenge(page, state):
                    logger.info("Challenge solved successfully")
                    return True

                await asyncio.sleep(1)

            return False

        except asyncio.TimeoutError:
            logger.error("Page load timed out")
            return False
        except Exception as e:
            logger.error(f"Solve error: {e}\n{traceback.format_exc()}")
            return False
        finally:
            if page:
                try:
                    await page.close()
                except Exception:
                    pass

    async def _click_checkbox(self, page: Any) -> bool:
        """Click the initial checkbox with robust error handling."""
        try:
            frame = self._detector._find_element(page, self._detector.HCAPTCHA_SELECTORS['frame'])
            if frame is None:
                return False

            if hasattr(frame, 'count'):
                count = await frame.count()
                if count == 0:
                    return False
            else:
                return False

            content_frame = await frame.content_frame()
            if content_frame is None:
                return False

            checkbox = self._detector._find_element(content_frame, self._detector.HCAPTCHA_SELECTORS['checkbox'])
            if checkbox is None:
                return False

            if hasattr(checkbox, 'count'):
                cb_count = await checkbox.count()
                if cb_count > 0:
                    await self._human_click(content_frame, checkbox)
                    return True

        except Exception as e:
            logger.debug(f"Checkbox click error: {e}")
        return False

    async def _solve_image_challenge(self, page: Any, state: ChallengeState) -> bool:
        """Solve image grid challenge with improved detection."""
        try:
            frame = self._detector._find_element(page, self._detector.HCAPTCHA_SELECTORS['frame'])
            if frame is None:
                return False

            content_frame = await frame.content_frame()
            if content_frame is None:
                return False

            cells = content_frame.locator('.task-image')
            cell_count = await cells.count()

            if cell_count == 0:
                logger.debug("No image cells found")
                return False

            to_click = []
            for i in range(min(cell_count, 9)):
                cell = cells.nth(i)
                box = await cell.bounding_box()
                if not box:
                    continue

                screenshot = await content_frame.screenshot(
                    clip={'x': box['x'], 'y': box['y'],
                          'width': box['width'], 'height': box['height']}
                )

                img_array = np.frombuffer(screenshot, np.uint8)
                image = cv2.imdecode(img_array, cv2.IMREAD_COLOR)
                if image is None:
                    continue

                image = self._vision.preprocess_image(image)

                target = state.target_label
                detections = self._vision.detect_objects(image, [target] if target else None)
                
                semantic = 0.0
                if target:
                    semantic = self._vision.semantic_match(image, target)

                confidence = max(
                    max(d.confidence for d in detections) if detections else 0,
                    semantic
                )

                if confidence > self.config.confidence_threshold:
                    to_click.append(cell)
                    logger.debug(f"Cell {i}: confidence={confidence:.2f}, detections={len(detections)}")

            for cell in to_click:
                await self._human_click(content_frame, cell)
                await asyncio.sleep(random.uniform(0.3, 0.8))

            submit = self._detector._find_element(content_frame, self._detector.HCAPTCHA_SELECTORS['submit_button'])
            if submit is not None:
                await self._human_click(content_frame, submit)

            await asyncio.sleep(3)
            result = await self._detector.detect_playwright(page)
            return result is None

        except Exception as e:
            logger.error(f"Image challenge solve error: {e}\n{traceback.format_exc()}")
            return False

    async def _human_click(self, frame: Any, locator: Any) -> None:
        """Human-like mouse click simulation."""
        try:
            box = await locator.bounding_box()
            if not box:
                await locator.click(timeout=5000)
                return

            x = box['x'] + random.uniform(box['width'] * 0.25, box['width'] * 0.75)
            y = box['y'] + random.uniform(box['height'] * 0.25, box['height'] * 0.75)

            steps = random.randint(8, 20) if self.config.human_like_mouse else 1
            await frame.mouse.move(x, y, steps=steps)
            await asyncio.sleep(random.uniform(0.05, 0.15))
            await frame.mouse.down()
            await asyncio.sleep(random.uniform(0.03, 0.1))
            await frame.mouse.up()

        except Exception:
            try:
                await locator.click(force=True)
            except Exception:
                pass

    async def close(self) -> None:
        await self._safe_close()
        self._initialized = False

