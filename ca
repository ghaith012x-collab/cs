    def __init__(self, config: SolverConfig):
        self.config = config
        self._device = torch.device('cuda' if torch.cuda.is_available() else 'cpu') if torch else None
        self._yolo_model: Optional[YOLO] = None
        self._clip_model = None
        self._clip_processor = None
        self._onnx_session = None
        self._model_lock = threading.Lock()
        self._init_models()

    def _init_models(self) -> None:
        self.config.model_dir.mkdir(parents=True, exist_ok=True)

        if ULTRALYTICS_AVAILABLE and self._yolo_model is None:
            try:
                model_path = self.config.model_dir / "yolov8n.pt"
                if not model_path.exists():
                    logger.info(f"Downloading YOLOv8n to {model_path}")
                    if torch:
                        torch.hub.download_url_to_file(
                            'https://github.com/ultralytics/assets/releases/download/v0.0.0/yolov8n.pt',
                            str(model_path)
                        )
                with self._model_lock:
                    self._yolo_model = YOLO(str(model_path))
                logger.info(f"YOLOv8n loaded on {self._device}")
                return
            except Exception as e:
                logger.warning(f"YOLO init failed: {e}")

        if ONNX_AVAILABLE and self._onnx_session is None:
            model_path = self.config.model_dir / "yolov8n.onnx"
            if model_path.exists():
                try:
                    self._onnx_session = ort.InferenceSession(str(model_path))
                    logger.info("ONNX Runtime loaded")
                    return
                except Exception as e:
                    logger.warning(f"ONNX init failed: {e}")

        logger.info("Using OpenCV heuristic fallback")

    def detect_objects(self, image: Any, target_classes: Optional[List[str]] = None) -> List[BoundingBox]:
        if self._yolo_model is not None:
            return self._detect_yolo(image, target_classes)
        if self._onnx_session is not None:
            return self._detect_onnx(image, target_classes)
        return self._detect_heuristic(image, target_classes)

    def _detect_yolo(self, image: Any, target_classes: Optional[List[str]]) -> List[BoundingBox]:
        results = self._yolo_model(image, verbose=False, conf=self.config.confidence_threshold)
        detections = []

        for result in results:
            if result.boxes is None:
                continue
            for box in result.boxes:
                cls_id = int(box.cls[0])
                label = self.COCO_CLASSES[cls_id] if cls_id < len(self.COCO_CLASSES) else f"class_{cls_id}"
                conf = float(box.conf[0])

                if target_classes and label not in target_classes:
                    continue

                coords = box.xyxy[0].cpu().numpy()
                detections.append(BoundingBox(
                    x1=float(coords[0]), y1=float(coords[1]),
                    x2=float(coords[2]), y2=float(coords[3]),
                    confidence=conf, label=label
                ))
        return detections

    def _detect_onnx(self, image: Any, target_classes: Optional[List[str]]) -> List[BoundingBox]:
        input_img = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)
        input_img = cv2.resize(input_img, (640, 640)).astype(np.float32) / 255.0
        input_img = np.transpose(input_img, (2, 0, 1))[np.newaxis, ...]

        outputs = self._onnx_session.run(None, {'images': input_img})
        return self._postprocess_onnx(outputs, image.shape[:2], target_classes)

    def _postprocess_onnx(self, outputs: Any, img_shape: Tuple[int, int], target_classes: Optional[List[str]]) -> List[BoundingBox]:
        detections = []
        return detections

    def _detect_heuristic(self, image: Any, target_classes: Optional[List[str]]) -> List[BoundingBox]:
        detections = []
        gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
        blurred = cv2.GaussianBlur(gray, (5, 5), 0)
        edges = cv2.Canny(blurred, 50, 150)

        contours, _ = cv2.findContours(edges, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

        for cnt in contours:
            area = cv2.contourArea(cnt)
            if area < 1000:
                continue

            x, y, width, height = cv2.boundingRect(cnt)
            aspect = width / height if height > 0 else 0
            label = self._classify_object(aspect, area, width, height)

            if target_classes and label not in target_classes:
                continue

            detections.append(BoundingBox(
                x1=float(x), y1=float(y), x2=float(x + width), y2=float(y + height),
                confidence=min(1.0, area / 50000), label=label
            ))

        return detections

    def _classify_object(self, aspect: float, area: float, width: int, height: int) -> str:
        if 0.8 < aspect < 1.2 and area > 5000:
            return 'sports ball'
        if aspect > 2.0 and area > 3000:
            return 'bus' if width > height else 'bench'
        if 1.2 < aspect < 2.0 and area > 4000:
            return 'car'
        if aspect < 0.5 and area > 2000:
            return 'traffic light'
        return 'object'

    def semantic_match(self, image: Any, text_query: str) -> float:
        if self._clip_model is None and TRANSFORMERS_AVAILABLE:
            try:
                self._clip_model = CLIPModel.from_pretrained("openai/clip-vit-base-patch32")
                self._clip_processor = CLIPProcessor.from_pretrained("openai/clip-vit-base-patch32")
            except Exception:
                pass

        if self._clip_model is not None:
            return self._clip_match(image, text_query)
        return self._histogram_match(image, text_query)

    def _clip_match(self, image: Any, text_query: str) -> float:
        try:
            from PIL import Image
            inputs = self._clip_processor(
                text=[text_query],
                images=Image.fromarray(cv2.cvtColor(image, cv2.COLOR_BGR2RGB)),
                return_tensors="pt", padding=True
            )
            outputs = self._clip_model(**inputs)
            return torch.sigmoid(outputs.logits_per_image[0][0]).item()
        except Exception:
            return 0.0

    def _histogram_match(self, image: Any, text_query: str) -> float:
        hsv = cv2.cvtColor(image, cv2.COLOR_BGR2HSV)

        color_map = {
            'car': ([90, 50, 50], [130, 255, 200]),
            'bus': ([10, 50, 50], [30, 255, 200]),
            'traffic light': ([0, 100, 100], [10, 255, 255]),
        }

        for keyword, (lower, upper) in color_map.items():
            if keyword in text_query.lower():
                mask = cv2.inRange(hsv, np.array(lower), np.array(upper))
                ratio = cv2.countNonZero(mask) / (image.shape[0] * image.shape[1])
                return min(1.0, ratio * 3)
        return 0.5

    def preprocess_image(self, image: Any) -> Any:
        denoised = cv2.fastNlMeansDenoisingColored(image, None, 10, 10, 7, 21)
        lab = cv2.cvtColor(denoised, cv2.COLOR_BGR2LAB)
        l, a, b = cv2.split(lab)
        clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8, 8))
        enhanced = cv2.cvtColor(cv2.merge([clahe.apply(l), a, b]), cv2.COLOR_LAB2BGR)
        return enhanced

    def create_grid_cells(self, image: Any, rows: int = 3, cols: int = 3) -> List[BoundingBox]:
        h, w = image.shape[:2]
        cell_h, cell_w = h // rows, w // cols

        cells = []
        for r in range(rows):
            for c in range(cols):
                x2 = (c + 1) * cell_w if c < cols - 1 else w
                y2 = (r + 1) * cell_h if r < rows - 1 else h
                cells.append(BoundingBox(
                    x1=float(c * cell_w), y1=float(r * cell_h),
                    x2=float(x2), y2=float(y2)
                ))
        return cells

